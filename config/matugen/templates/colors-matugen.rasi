/**
 * Rofi dynamic colors generated by matugen
 **/

* {
    background:     {{colors.background.default.hex}}FF;
    background-alt: {{colors.surface_container.default.hex}}FF;
    foreground:     {{colors.on_background.default.hex}}FF;
    selected:       {{colors.primary.default.hex}}FF;
    active:         {{colors.secondary.default.hex}}FF;
    urgent:         {{colors.error.default.hex}}FF;
}
