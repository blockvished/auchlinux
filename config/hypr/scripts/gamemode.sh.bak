#!/usr/bin/env bash

HYPRGAMEMODE=$(hyprctl getoption animations:enabled | awk 'NR==1 {print $2}')

if [ "$HYPRGAMEMODE" = "true" ]; then
    hyprctl eval "hl.config({ animations = { enabled = false }, decoration = { shadow = { enabled = false }, blur = { enabled = false }, rounding = 0 } })"
    notify-send -a "Game Mode" -i "dialog-information" -u low "Game Mode" "Performance Mode Enabled (Effects Disabled)"
else
    hyprctl eval "hl.config({ animations = { enabled = true }, decoration = { shadow = { enabled = true }, blur = { enabled = true }, rounding = 10 } })"
    notify-send -a "Game Mode" -i "dialog-information" -u low "Game Mode" "Aesthetic Mode Restored"
fi
