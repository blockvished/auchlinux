#!/bin/bash

WALLPAPER_DIR="$HOME/Pictures/wallpapers"

if [[ -z "$1" ]]; then
    echo "Usage: wallpaper-theme <wallpaper_name|list|random>"
    exit 0
fi

# Ensure awww is running
awww query >/dev/null 2>&1 || awww-daemon >/dev/null 2>&1 &

if [[ "$1" == "list" ]]; then
    ls -1 "$WALLPAPER_DIR"
    exit 0
elif [[ "$1" == "random" ]]; then
    WP=$(find "$WALLPAPER_DIR" -type f | shuf -n 1)
else
    # Find matching wallpaper
    WP=$(find "$WALLPAPER_DIR" -type f -iname "*$1*" | head -n 1)
fi

if [[ -f "$WP" ]]; then
    echo "Setting wallpaper: $(basename "$WP")"
    awww img "$WP" --transition-type grow --transition-pos 0.5,0.5 --transition-step 90
    ln -sf "$WP" "$HOME/.cache/current_wallpaper_image"
    
    # Save the current wallpaper path so it can be restored on boot
    echo "$WP" > "$HOME/Pictures/wallpapers/.current_wallpaper"
else
    echo "Error: Wallpaper '$1' not found."
    exit 1
fi
